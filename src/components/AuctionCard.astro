---
import type { Auction } from '@/lib/types';
import { formatPrice, formatNumber, isHot } from '@/lib/format';
import CountdownTimer from '@/components/CountdownTimer.astro';

interface Props {
  auction: Auction;
  class?: string;
}
const { auction, class: className = '' } = Astro.props;
const hot = isHot(auction.bids) && auction.status === 'active';
const ended = auction.status === 'ended';
const upcoming = auction.status === 'upcoming';
---

<article
  class:list={[
    'card group relative flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1',
    className,
  ]}
  style="--tw-shadow: var(--shadow-card);"
  data-auction-id={auction.id}
>
  <a href={`/auction/${auction.slug}`} class="relative block aspect-[4/3] overflow-hidden">
    <img
      src={auction.image}
      alt={`${auction.title} ${auction.year}`}
      width="800"
      height="600"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      onerror="this.onerror=null;this.src='https://picsum.photos/seed/'+this.closest('[data-auction-id]').dataset.auctionId+'/800/600';"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"></div>

    <!-- Status / hot badges -->
    <div class="absolute left-3 top-3 flex flex-wrap gap-2">
      {auction.deluxe && (
        <span class="inline-flex items-center gap-1 rounded-full bg-black/70 px-2.5 py-1 text-[11px] font-semibold text-gold-soft backdrop-blur">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.5 5.5L20 8l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z" /></svg>
          Deluxe
        </span>
      )}
      {hot && (
        <span class="inline-flex items-center gap-1 rounded-full bg-hot px-2.5 py-1 text-[11px] font-semibold text-white shadow">
          🔥 Caliente
        </span>
      )}
      {ended && (
        <span class="rounded-full bg-black/70 px-2.5 py-1 text-[11px] font-semibold text-white/90 backdrop-blur">Finalizada</span>
      )}
      {upcoming && (
        <span class="rounded-full bg-secondary px-2.5 py-1 text-[11px] font-semibold backdrop-blur" style="color:#222">Próxima</span>
      )}
    </div>

    <!-- Timer overlay -->
    {!upcoming && (
      <div class="absolute bottom-3 left-3 rounded-full bg-black/65 px-3 py-1 text-xs text-white backdrop-blur">
        <CountdownTimer endsAt={auction.endsAt} />
      </div>
    )}
  </a>

  <!-- Favorite (nanostores-backed) -->
  <button
    type="button"
    class="watch-btn absolute right-3 top-3 grid h-9 w-9 place-items-center rounded-full bg-white/90 text-content shadow-md backdrop-blur transition-transform hover:scale-110 dark:bg-black/60 dark:text-white"
    data-id={auction.id}
    aria-label="Guardar en seguidos"
    aria-pressed="false"
  >
    <svg class="heart-outline h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 21s-7-4.5-9.5-9A5 5 0 0112 5a5 5 0 019.5 7c-2.5 4.5-9.5 9-9.5 9z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <svg class="heart-filled hidden h-5 w-5 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 21s-7-4.5-9.5-9A5 5 0 0112 5a5 5 0 019.5 7c-2.5 4.5-9.5 9-9.5 9z" />
    </svg>
  </button>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-2">
      <div>
        <h3 class="font-display text-base font-semibold leading-tight text-content">
          <a href={`/auction/${auction.slug}`} class="after:absolute after:inset-0 hover:text-primary">
            {auction.title}
          </a>
        </h3>
        <p class="mt-0.5 text-xs text-muted">{auction.year} · {formatNumber(auction.mileageKm)} km · {auction.location}</p>
      </div>
    </div>

    <div class="mt-3 flex flex-wrap gap-1.5">
      {[auction.fuel, auction.transmission, auction.category].map((tag) => (
        <span class="rounded-md bg-surface-2 px-2 py-0.5 text-[11px] font-medium text-muted">{tag}</span>
      ))}
    </div>

    <div class="mt-auto flex items-end justify-between gap-3 border-t border-border pt-4">
      <div>
        <p class="text-[11px] uppercase tracking-wide text-muted">
          {ended ? 'Adjudicado en' : upcoming ? 'Precio base' : 'Oferta actual'}
        </p>
        <p class="font-display text-xl font-bold text-content">
          {formatPrice(upcoming ? auction.basePrice : auction.currentBid)}
        </p>
      </div>
      <div class="text-right">
        <p class="text-[11px] uppercase tracking-wide text-muted">Pujas</p>
        <p class="font-semibold text-primary">{auction.bids}</p>
      </div>
    </div>
  </div>
</article>

<script>
  import { watchlist, toggleWatch } from '@/stores/watchlist';

  function render(ids: string[]) {
    document.querySelectorAll<HTMLButtonElement>('.watch-btn').forEach((btn) => {
      const on = ids.includes(btn.dataset.id || '');
      btn.setAttribute('aria-pressed', String(on));
      btn.querySelector('.heart-outline')?.classList.toggle('hidden', on);
      btn.querySelector('.heart-filled')?.classList.toggle('hidden', !on);
    });
  }

  function bindWatch() {
    document.querySelectorAll<HTMLButtonElement>('.watch-btn').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        if (btn.dataset.id) toggleWatch(btn.dataset.id);
      });
    });
    render(watchlist.get());
  }

  watchlist.subscribe(render);
  bindWatch();
  document.addEventListener('astro:after-swap', bindWatch);
</script>
