---
import Logo from '@/components/Logo.astro';
import { siteConfig } from '@/data/site';

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Subastas',
    links: [
      { label: 'Activas', href: '/auctions' },
      { label: 'Próximas', href: '/auctions?status=upcoming' },
      { label: 'Finalizadas', href: '/auctions?status=ended' },
      { label: 'Cómo pujar', href: '/about' },
    ],
  },
  {
    title: 'CarsHub Deluxe',
    links: [
      { label: 'Beneficios', href: '/deluxe' },
      { label: 'Planes y precios', href: '/deluxe#precios' },
      { label: 'Subastas exclusivas', href: '/deluxe' },
      { label: 'Preguntas frecuentes', href: '/deluxe#faq' },
    ],
  },
  {
    title: 'Compañía',
    links: [
      { label: 'Acerca de', href: '/about' },
      { label: 'Contacto', href: '/contact' },
      { label: 'Términos', href: '#' },
      { label: 'Privacidad', href: '#' },
    ],
  },
];

const socials = [
  { label: 'Instagram', href: siteConfig.social.instagram, icon: 'M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm5 5a5 5 0 100 10 5 5 0 000-10zm6.5-.5a1 1 0 100 2 1 1 0 000-2z' },
  { label: 'Facebook', href: siteConfig.social.facebook, icon: 'M14 9h3V6h-3a4 4 0 00-4 4v2H7v3h3v6h3v-6h2.5l.5-3H13v-1a1 1 0 011-1z' },
  { label: 'YouTube', href: siteConfig.social.youtube, icon: 'M22 8.2a3 3 0 00-2.1-2.1C18 5.5 12 5.5 12 5.5s-6 0-7.9.6A3 3 0 002 8.2 31 31 0 002 12a31 31 0 00.1 3.8A3 3 0 004.1 18c1.9.6 7.9.6 7.9.6s6 0 7.9-.6a3 3 0 002.1-2.2A31 31 0 0022 12a31 31 0 00-.1-3.8zM10 15V9l5 3-5 3z' },
];
---

<footer class="mt-24 border-t border-border bg-surface-2">
  <div class="container-app grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-[1.4fr_repeat(3,1fr)]">
    <div class="max-w-sm">
      <Logo />
      <p class="mt-4 text-sm leading-relaxed text-muted">
        {siteConfig.description}
      </p>
      <div class="mt-6 flex gap-3">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="grid h-10 w-10 place-items-center rounded-full border border-border text-muted transition-colors hover:border-primary hover:bg-primary hover:text-white"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={s.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    {
      columns.map((col) => (
        <div>
          <h3 class="font-display text-sm font-semibold text-content">{col.title}</h3>
          <ul class="mt-4 space-y-3">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-muted transition-colors hover:text-primary">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="border-t border-border">
    <div class="container-app flex flex-col items-center justify-between gap-3 py-6 text-sm text-muted sm:flex-row">
      <p>© {year} {siteConfig.name}. Hecho en el Perú con estándares globales.</p>
      <p class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-live"></span>
        Subastas en vivo · {siteConfig.phone}
      </p>
    </div>
  </div>
</footer>
