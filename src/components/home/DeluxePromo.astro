---
const benefits = [
  { title: 'Subastas exclusivas', desc: 'Acceso a lotes de lujo internacionales antes que nadie.', icon: 'M12 2l2.5 5.5L20 8l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z' },
  { title: 'Puja automática', desc: 'Define tu límite y deja que CarsHub puje por ti.', icon: 'M13 2L3 14h7l-1 8 10-12h-7l1-8z' },
  { title: 'Asesor personalizado', desc: 'Un experto te acompaña en toda la compra.', icon: 'M12 12a4 4 0 100-8 4 4 0 000 8zm-7 9a7 7 0 0114 0' },
  { title: 'Inspección 360°', desc: 'Recorre cada vehículo en realidad virtual.', icon: 'M2 12a10 10 0 0020 0 10 10 0 00-20 0zm10-8v16M4 8h16M4 16h16' },
];
---

<section class="relative overflow-hidden bg-[#141414] py-20 lg:py-28">
  <!-- Gold ambiance -->
  <div class="pointer-events-none absolute inset-0 -z-0">
    <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-gold/10 blur-3xl"></div>
    <div class="absolute -right-10 bottom-0 h-80 w-80 rounded-full bg-primary/10 blur-3xl"></div>
  </div>

  <div class="container-app relative grid gap-14 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full border border-gold/30 bg-gold/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-gold-soft">
        ✦ CarsHub Deluxe
      </p>
      <h2 class="mt-6 font-display text-3xl font-extrabold leading-tight text-white sm:text-4xl lg:text-5xl">
        Una experiencia de subasta
        <span class="bg-gradient-to-r from-gold-soft to-gold bg-clip-text text-transparent"> de clase mundial</span>.
      </h2>
      <p class="mt-5 max-w-lg text-lg leading-relaxed text-white/65">
        Compite por los autos más codiciados del planeta con herramientas premium, atención prioritaria
        24/7 y un historial completo de cada vehículo. Diseñado para coleccionistas exigentes.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/deluxe" class="btn text-base text-[#141414] shadow-lg" style="background-image:linear-gradient(135deg,#e8c874,#d4af37)">
          Conocer Deluxe
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
        <a href="/deluxe#precios" class="btn border border-white/20 text-white hover:border-gold hover:text-gold">Ver planes</a>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        benefits.map((b) => (
          <div class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-gold/40 hover:bg-white/[0.06]">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-gold/10 text-gold-soft transition-colors group-hover:bg-gold group-hover:text-[#141414]">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={b.icon} />
              </svg>
            </span>
            <h3 class="mt-4 font-display text-lg font-semibold text-white">{b.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-white/60">{b.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
