---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<a href="/" class={`group inline-flex items-center gap-2.5 ${className}`} aria-label="CarsHub — inicio">
  <span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-primary to-primary-700 text-white shadow-lg shadow-primary/30 transition-transform group-hover:scale-105">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 16l1.5-4.5A2 2 0 018.4 10h7.2a2 2 0 011.9 1.5L19 16" />
      <path d="M4 16h16v2a1 1 0 01-1 1h-1a1 1 0 01-1-1v-1H7v1a1 1 0 01-1 1H5a1 1 0 01-1-1v-2z" />
      <circle cx="7.5" cy="16" r="0.5" fill="currentColor" />
      <circle cx="16.5" cy="16" r="0.5" fill="currentColor" />
    </svg>
  </span>
  <span class="font-display text-xl font-extrabold tracking-tight text-content">
    Cars<span class="text-primary">Hub</span>
  </span>
</a>
