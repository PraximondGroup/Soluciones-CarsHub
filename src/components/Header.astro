---
import Logo from '@/components/Logo.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import { navLinks } from '@/data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-border/80 bg-bg/80 backdrop-blur-xl">
  <div class="container-app flex h-16 items-center justify-between gap-4 lg:h-18">
    <Logo />

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Principal">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative rounded-full px-4 py-2 text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-primary'
                : 'text-muted hover:text-content',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute inset-x-4 -bottom-px h-0.5 rounded-full bg-primary" />
            )}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <!-- Quick search -->
      <form action="/auctions" method="get" class="hidden md:block" role="search">
        <label class="relative block">
          <span class="sr-only">Buscar autos</span>
          <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" stroke-linecap="round" />
          </svg>
          <input
            type="search"
            name="q"
            placeholder="Buscar marca, modelo…"
            class="w-44 rounded-full border border-border bg-surface py-2 pl-9 pr-3 text-sm text-content placeholder:text-muted/70 transition-all focus:w-60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 xl:w-56"
          />
        </label>
      </form>

      <ThemeToggle />

      <a href="/profile" class="hidden sm:inline-flex btn-ghost px-4 py-2">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0116 0" stroke-linecap="round" />
        </svg>
        <span>Ingresar</span>
      </a>

      <!-- Mobile menu button -->
      <button
        type="button"
        id="menu-toggle"
        class="grid h-10 w-10 place-items-center rounded-full border border-border bg-surface text-content lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-bg lg:hidden">
    <nav class="container-app flex flex-col gap-1 py-4" aria-label="Móvil">
      <form action="/auctions" method="get" class="mb-2" role="search">
        <input
          type="search"
          name="q"
          placeholder="Buscar marca, modelo…"
          class="w-full rounded-full border border-border bg-surface px-4 py-2.5 text-sm text-content placeholder:text-muted/70 focus:border-primary focus:outline-none"
        />
      </form>
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-xl px-4 py-3 text-base font-medium transition-colors',
              isActive(link.href) ? 'bg-primary/10 text-primary' : 'text-content hover:bg-surface',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a href="/profile" class="btn-primary mt-2 w-full">Ingresar / Registrarse</a>
    </nav>
  </div>
</header>

<script>
  function bindMenu() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu || btn.dataset.bound) return;
    btn.dataset.bound = 'true';
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
    });
  }
  bindMenu();
  document.addEventListener('astro:after-swap', bindMenu);
</script>
